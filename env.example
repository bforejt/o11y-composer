# =============================================================================
# Network Observability Stack — Environment Configuration
#
# Copy to .env and customize, or run setup.sh to auto-generate with secrets.
# =============================================================================

# --- Image Versions ----------------------------------------------------------
# Pin these for production. Use 'latest' for lab/dev.
PROMETHEUS_VERSION=latest
GRAFANA_VERSION=latest
LOKI_VERSION=latest
ALERTMANAGER_VERSION=latest
ALLOY_VERSION=latest
POSTGRES_VERSION=16
SNMP_EXPORTER_VERSION=latest
TELEGRAF_VERSION=latest
MCP_GRAFANA_VERSION=latest
# MCP_PROMETHEUS_VERSION=latest

# --- Port Mappings -----------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
SNMP_EXPORTER_PORT=9116
ALLOY_SYSLOG_UDP_PORT=1514
ALLOY_SYSLOG_TCP_PORT=1514
ALLOY_UI_PORT=12345
MCP_GRAFANA_PORT=8686
# MCP_PROMETHEUS_PORT=8687

# --- PostgreSQL (Grafana backend) --------------------------------------------
GF_DATABASE_NAME=grafana
GF_DATABASE_USER=grafana
GF_DATABASE_PASSWORD=change_me

# --- Grafana -----------------------------------------------------------------
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me
# Comma-separated list of plugins to install on startup
# GF_INSTALL_PLUGINS=grafana-clock-panel,grafana-piechart-panel

# --- Prometheus --------------------------------------------------------------
PROMETHEUS_RETENTION=30d

# --- MCP Servers -------------------------------------------------------------
# Grafana service account API key (create in Grafana → Administration → Service Accounts)
# Required for mcp-grafana. Leave empty for initial setup, then generate via Grafana UI.
MCP_GRAFANA_API_KEY=

# --- Nautobot Integration (for service discovery script) ---------------------
# NAUTOBOT_URL=https://nautobot.lab:8443
# NAUTOBOT_TOKEN=your_nautobot_api_token
